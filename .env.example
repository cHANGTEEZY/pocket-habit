# PocketBase server URL (no trailing slash).
# Start locally with: npm run pocketbase
#   (binds to 0.0.0.0:8090 so phones on your LAN can connect)
# Admin UI: http://127.0.0.1:8090/_/
#
# On a physical device, use your Mac's LAN IP (see Expo "Metro: exp://IP:8081"):
#   EXPO_PUBLIC_POCKETBASE_URL=http://192.168.x.x:8090
# localhost / 127.0.0.1 is also rewritten automatically when Metro host is available.
EXPO_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Restart Metro after changing env vars: npx expo start --clear
